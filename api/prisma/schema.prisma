// Prisma Schema for CarbonIQ
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  greenScore    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions TransactionAnalysis[]
  impacts      ImpactRecord[]
  stakes       StakeRecord[]
}

model TransactionAnalysis {
  id               String   @id @default(cuid())
  signature        String   @unique
  userId           String
  computeUnits     Int
  estimatedCO2     Float
  transactionType  String
  analyzedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model ImpactRecord {
  id              String   @id @default(cuid())
  userId          String
  co2OffsetGrams  Int
  creditType      String   @default("forestry")
  toucanTxHash    String?
  onChainTxHash   String?
  proofPda        String?
  status          String   @default("pending")
  recordedAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model StakeRecord {
  id              String   @id @default(cuid())
  userId          String
  amount          Float
  durationDays    Int
  greenScore      Int
  effectiveApy    Float
  estimatedYield  Float
  solanaTxHash    String?  @unique
  vaultAddress    String?
  status          String   @default("simulated")
  simulatedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
