# CarbonIQ API Environment
PORT=4000
FRONTEND_URL=http://localhost:5173
# Preferred: a direct `mongodb://...` URI if your network has trouble with
# Atlas SRV lookups. The API also accepts DATABASE_URL for backward compatibility.
MONGODB_URI="mongodb://USERNAME:PASSWORD@HOST1:27017,HOST2:27017,HOST3:27017/carboniq?replicaSet=REPLICA_SET_NAME&authSource=admin&retryWrites=true&w=majority"
DATABASE_URL=""
SOLANA_RPC_URL=https://api.devnet.solana.com
# Deployed Anchor program ID (update after `anchor deploy`)
SOLANA_PROGRAM_ID=99ZkMZawmHYwNPyQzseCbEbJFs6mxEYyhJrwdYGadCsR
# Base58 or JSON-array secret key of the API payer wallet (devnet only!)
SOLANA_PAYER_SECRET_KEY=
# Devnet vault that receives demo staking transfers
SOLANA_STAKING_VAULT_ADDRESS=
# Swap recommendations should use the OpenAI recommender when an API key is present.
# Set this to false only if you want deterministic template-only suggestions.
CARBONIQ_USE_OPENAI_RECOMMENDER=true
# Optional legacy phrasing-only narrator mode. Leave false unless you specifically
# want rewrite-only behavior instead of the recommender.
CARBONIQ_USE_OPENAI_NARRATOR=false
# Keep OpenAI disabled in tests by default; set true only when intentionally
# validating live model behavior in test mode.
CARBONIQ_FORCE_OPENAI_IN_TEST=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CARBONIQ_OPENAI_MODEL=gpt-5-mini
CARBONIQ_HTTP_TIMEOUT_SECONDS=10
CARBONIQ_OPENAI_RECOMMENDER_MAX_OUTPUT_TOKENS=900
