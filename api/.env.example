# CarbonIQ API Environment
PORT=4000
FRONTEND_URL=http://localhost:3000
DATABASE_URL="file:./dev.db"
SOLANA_RPC_URL=https://api.devnet.solana.com
# Deployed Anchor program ID (update after `anchor deploy`)
SOLANA_PROGRAM_ID=99ZkMZawmHYwNPyQzseCbEbJFs6mxEYyhJrwdYGadCsR
# Base58 or JSON-array secret key of the API payer wallet (devnet only!)
SOLANA_PAYER_SECRET_KEY=
# Devnet vault that receives demo staking transfers
SOLANA_STAKING_VAULT_ADDRESS=
# Optional AI narrator controls for swap-suggestion phrasing
CARBONIQ_USE_OPENAI_NARRATOR=false
# Optional AI recommendation agent for alternative product phrasing
# (falls back to deterministic templates when unavailable)
CARBONIQ_USE_OPENAI_RECOMMENDER=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CARBONIQ_OPENAI_MODEL=gpt-5-mini
CARBONIQ_HTTP_TIMEOUT_SECONDS=10
